{
  "name": "key-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/show-ip.js && node -e \"fs.rmSync('.next', {recursive:true,force:true})\" && next dev -H 0.0.0.0",
    "dev:safe": "node scripts/show-ip.js && node -e \"fs.rmSync('.next', {recursive:true,force:true})\" && next dev -H 0.0.0.0",
    "build": "next build",
    "start": "node scripts/show-ip.js && next start -H 0.0.0.0",
    "lint": "eslint",
    "postinstall": "npm rebuild better-sqlite3 && node scripts/init-db.js"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "jose": "^6.1.3",
    "next": "16.2.6",
    "node-cron": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "brace-expansion": "^2.0.3",
    "fast-uri": "^3.1.2",
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
